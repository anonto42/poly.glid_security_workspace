{
  "name": "rust-core",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --all"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --all"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo check"
      }
    }
  }
}
